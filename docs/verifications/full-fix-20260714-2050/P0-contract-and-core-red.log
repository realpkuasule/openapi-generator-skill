ath, "code": code, "message": message}\n\n\ndef load_profile(path: Path) -> Any:\n    text = path.read_text(encoding="utf-8")\n    if path.suffix.lower() == ".json":\n        return json.loads(text)\n    try:\n        import yaml\n    except ImportError as exc:\n        raise RuntimeError(\n            "YAML support requires PyYAML; it was not installed automatically."\n        ) from exc\n    try:\n        return yaml.safe_load(text)\n    except yaml.YAMLError:\n        raise ValueError("Profile is not valid YAML.") from None\n\n\ndef find_sensitive_fields(value: Any, path: str = "$") -> list[dict[str, str]]:\n    errors: list[dict[str, str]] = []\n    if isinstance(value, dict):\n        for key, child in value.items():\n            child_path = f"{path}.{key}"\n            if SENSITIVE_KEY.search(str(key)):\n                errors.append(\n                    finding(\n                        child_path,\n                        "sensitive-field",\n                        "Governance profiles must not contain credential or secret fields.",\n                    )\n                )\n            errors.extend(find_sensitive_fields(child, child_path))\n    elif isinstance(value, list):\n        for index, child in enumerate(value):\n            errors.extend(find_sensitive_fields(child, f"{path}[{index}]"))\n    return errors\n\n\ndef validate_tool_list(value: Any, path: str) -> list[dict[str, str]]:\n    errors: list[dict[str, str]] = []\n    if not isinstance(value, list):\n        return [finding(path, "invalid-type", "Expected an array of pinned tools.")]\n    for index, tool in enumerate(value):\n        tool_path = f"{path}[{index}]"\n        if not isinstance(tool, dict):\n            errors.append(finding(tool_path, "invalid-type", "Expected a tool object."))\n            continue\n        unknown = set(tool) - {"name", "version"}\n        for key in sorted(unknown):\n            errors.append(finding(f"{tool_path}.{key}", "unexpected-field", "Unexpected tool field."))\n        for key in ("name", "version"):\n            if not isinstance(tool.get(key), str) or not tool[key].strip():\n                errors.append(finding(f"{tool_path}.{key}", "missing-field", "A non-empty value is required."))\n        version = tool.get("version")\n        if isinstance(version, str) and version.strip().lower() == "latest":\n            errors.append(\n                finding(\n                    f"{tool_path}.version",\n                    "unpinned-version",\n                    "Tool versions must be pinned and cannot use latest.",\n                )\n            )\n    return errors\n\n\ndef validate(profile: Any) -> list[dict[str, str]]:\n    if not isinstance(profile, dict):\n        return [finding("$", "invalid-type", "Profile must be an object.")]\n\n    errors: list[dict[str, str]] = []\n    missing = TOP_LEVEL_FIELDS - set(profile)\n    for key in sorted(missing):\n        errors.append(finding(f"$.{key}", "missing-field", "Required section is missing."))\n    for key in sorted(set(profile) - TOP_LEVEL_FIELDS):\n        errors.append(finding(f"$.{key}", "unexpected-field", "Unexpected top-level field."))\n\n    if profile.get("profile_version") != 1:\n        errors.append(finding("$.profile_version", "unsupported-version", "profile_version must be 1."))\n\n    for section, allowed in SECTION_FIELDS.items():\n        value = profile.get(section)\n        if value is None:\n            continue\n        if not isinstance(value, dict):\n            errors.append(finding(f"$.{section}", "invalid-type", "Section must be an object."))\n            continue\n        for key in sorted(allowed - set(value)):\n            errors.append(finding(f"$.{section}.{key}", "missing-field", "Required field is missing."))\n        for key in sorted(set(value) - allowed):\n            errors.append(finding(f"$.{section}.{key}", "unexpected-field", "Unexpected field."))\n\n    project = profile.get("project")\n    if isinstance(project, dict):\n        if project.get("kind") not in PROJECT_KINDS:\n            errors.append(finding("$.project.kind", "invalid-enum", "Unknown project kind."))\n        if project.get("stage") not in PROJECT_STAGES:\n            errors.append(finding("$.project.stage", "invalid-enum", "Unknown project stage."))\n\n    contract = profile.get("contract")\n    if isinstance(contract, dict):\n        if contract.get("approach") not in CONTRACT_APPROACHES:\n            errors.append(finding("$.contract.approach", "invalid-enum", "Unknown contract approach."))\n        version = contract.get("openapi_version")\n        if version is not None and (not isinstance(version, str) or not OPENAPI_VERSION.fullmatch(version)):\n            errors.append(finding("$.contract.openapi_version", "invalid-format", "Expected an OpenAPI 3.x version."))\n\n    decision = profile.get("decision")\n    if isinstance(decision, dict):\n        if decision.get("strategy") not in STRATEGIES:\n            errors.append(finding("$.decision.strategy", "invalid-enum", "Unknown decision strategy."))\n        errors.extend(validate_tool_list(decision.get("tools"), "$.decision.tools"))\n\n    generation = profile.get("generation")\n    if isinstance(generation, dict):\n        errors.extend(validate_tool_list(generation.get("version_pins"), "$.generation.version_pins"))\n\n    errors.extend(find_sensitive_fields(profile))\n    unique = {(item["path"], item["code"], item["message"]): item for item in errors}\n    return [unique[key] for key in sorted(unique)]\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description="Validate an OpenAPI engineering governance profile.")\n    parser.add_argument("profile", help="YAML or JSON governance profile path.")\n    parser.add_argument("--pretty", action="store_true", help="Pretty-print JSON output.")\n    args = parser.parse_args()\n    profile_path = Path(args.profile).expanduser().resolve()\n\n    try:\n        profile = load_profile(profile_path)\n    except (OSError, ValueError, RuntimeError) as exc:\n        emit(\n            {\n                "status": "error",\n                "error": {"code": "load-error", "message": str(exc)},\n            },\n            args.pretty,\n        )\n        return 2\n\n    errors = validate(profile)\n    emit(\n        {"status": "ok", "valid": not errors, "errors": errors, "warnings": []},\n        args.pretty,\n    )\n    return 0 if not errors else 1\n\n\nif __name__ == "__main__":\n    raise SystemExit(main())\n'

