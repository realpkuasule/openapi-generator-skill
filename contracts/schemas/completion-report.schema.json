{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/completion-report.schema.json",
  "title": "OpenAPI Engineering Completion Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "changed_files", "commands", "results", "unverified", "risks", "rollback", "profile_changes"],
  "properties": {
    "outcome": { "type": "string", "minLength": 1 },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "commands": { "type": "array", "items": { "type": "string" } },
    "results": { "type": "array", "items": { "type": "string" } },
    "unverified": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "rollback": { "type": "array", "items": { "type": "string" } },
    "profile_changes": { "type": "array", "items": { "type": "string" } }
  }
}
