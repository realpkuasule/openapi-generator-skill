{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/eval-result.schema.json",
  "title": "OpenAPI Engineering Skill Evaluation Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "adapter", "platform_version", "input_sha256", "status", "turns", "file_hashes", "scores", "unverified"],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "adapter": { "enum": ["fake", "codex", "claude"] },
    "platform_version": { "type": "string", "minLength": 1 },
    "input_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": { "enum": ["passed", "failed", "blocked"] },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": { "enum": ["user", "assistant", "tool"] },
          "content": { "type": "string" }
        }
      }
    },
    "boundary_summary": { "type": ["object", "null"] },
    "approval_transition": { "type": ["string", "null"] },
    "tool_decision": { "type": ["object", "null"] },
    "file_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after"],
      "properties": {
        "before": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "after": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "unverified": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
