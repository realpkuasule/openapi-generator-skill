{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/maintenance-finding.schema.json",
  "title": "OpenAPI Engineering Maintenance Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_id",
    "rule_id",
    "threshold_version",
    "period_id",
    "input_sha256",
    "observed",
    "severity",
    "requires_secondary_review",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "finding_id": { "type": "string", "pattern": "^finding-[a-f0-9]{16,64}$" },
    "rule_id": { "$ref": "#/$defs/rule_id" },
    "threshold_version": { "const": 1 },
    "period_id": { "type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$" },
    "input_sha256": { "$ref": "#/$defs/sha256" },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "value", "comparator", "threshold", "sample_count", "window_days"],
      "properties": {
        "metric": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
        "value": { "type": "number" },
        "comparator": { "enum": [">", ">=", "=="] },
        "threshold": { "type": "number" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "window_days": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "severity": { "enum": ["P0", "P1", "P2"] },
    "requires_secondary_review": { "type": "boolean" },
    "status": { "enum": ["open", "acknowledged", "resolved", "blocked"] }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "finding_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "period_id", "input_sha256", "findings"],
      "properties": {
        "schema_version": { "const": 1 },
        "period_id": { "type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$" },
        "input_sha256": { "$ref": "#/$defs/sha256" },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "https://openapi-engineering.local/schemas/maintenance-finding.schema.json"
          }
        }
      }
    },
    "rule_id": {
      "enum": [
        "SI-SAFETY-001",
        "SI-PLATFORM-001",
        "SI-FRICTION-001",
        "SI-OVERRIDE-001",
        "SI-UNVERIFIED-001",
        "SI-INTERVIEW-001",
        "SI-RESOURCE-001",
        "SI-REGRESSION-001"
      ]
    }
  }
}
