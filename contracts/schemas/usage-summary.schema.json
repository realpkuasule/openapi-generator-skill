{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/usage-summary.schema.json",
  "title": "OpenAPI Engineering Usage Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "period_id",
    "generated_at",
    "input_sha256",
    "threshold_version",
    "device_count",
    "sample_count",
    "metrics",
    "data_completeness",
    "triggered_rule_ids"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "period_id": { "type": "string", "pattern": "^(?:[0-9]{4}-W[0-9]{2}|rolling-(?:30d|90d)-[0-9]{4}-[0-9]{2}-[0-9]{2})$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "input_sha256": { "$ref": "#/$defs/sha256" },
    "threshold_version": { "const": 1 },
    "device_count": { "type": "integer", "minimum": 0 },
    "sample_count": { "type": "integer", "minimum": 0 },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcomes",
        "tool_override_ratio",
        "unverified_ratio",
        "interview_median",
        "interview_max",
        "peak_rss_max_mb",
        "peak_rss_baseline_mb"
      ],
      "properties": {
        "outcomes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "partial", "failed", "blocked"],
          "properties": {
            "passed": { "type": "integer", "minimum": 0 },
            "partial": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "blocked": { "type": "integer", "minimum": 0 }
          }
        },
        "tool_override_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "unverified_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "interview_median": { "type": ["number", "null"], "minimum": 0 },
        "interview_max": { "type": ["integer", "null"], "minimum": 0 },
        "peak_rss_max_mb": { "type": ["number", "null"], "minimum": 0 },
        "peak_rss_baseline_mb": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "data_completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_measurements", "unavailable_measurements"],
      "properties": {
        "available_measurements": { "type": "integer", "minimum": 0 },
        "unavailable_measurements": { "type": "integer", "minimum": 0 }
      }
    },
    "triggered_rule_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SI-[A-Z]+-001$" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
