{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/maintenance-cycle.schema.json",
  "title": "OpenAPI Engineering Unattended Maintenance Cycle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle_version",
    "cycle_id",
    "status",
    "period_id",
    "input_sha256",
    "authorization_sha256",
    "sync",
    "finding_count",
    "analysis_status",
    "report_id",
    "notification",
    "attempt"
  ],
  "properties": {
    "cycle_version": { "const": 1 },
    "cycle_id": { "type": "string", "pattern": "^cycle-[a-f0-9]{16,64}$" },
    "status": {
      "enum": [
        "sync-blocked",
        "no-findings",
        "completed",
        "blocked",
        "failed",
        "duplicate",
        "retry-exhausted"
      ]
    },
    "period_id": { "type": ["string", "null"], "pattern": "^[0-9]{4}-W[0-9]{2}$" },
    "input_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "authorization_sha256": { "$ref": "#/$defs/sha256" },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "synchronized", "pending", "reason_code"],
      "properties": {
        "status": { "enum": ["ok", "blocked"] },
        "synchronized": { "type": "integer", "minimum": 0 },
        "pending": { "type": "integer", "minimum": 0 },
        "reason_code": { "type": ["string", "null"], "maxLength": 80 }
      }
    },
    "finding_count": { "type": "integer", "minimum": 0 },
    "analysis_status": { "enum": ["not-run", "completed", "blocked", "failed"] },
    "report_id": {
      "type": ["string", "null"],
      "pattern": "^report-[a-f0-9]{16,64}$"
    },
    "notification": { "enum": ["not-required", "sent", "skipped", "failed"] },
    "attempt": { "type": "integer", "minimum": 0, "maximum": 2 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
