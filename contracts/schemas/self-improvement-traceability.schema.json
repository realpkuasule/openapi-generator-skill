{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/self-improvement-traceability.schema.json",
  "title": "OpenAPI Engineering Self-Improvement Traceability Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_version",
    "status",
    "acceptance_complete",
    "manifest_sha256",
    "generated_at",
    "requirements",
    "completion_report"
  ],
  "properties": {
    "report_version": { "const": 1 },
    "status": { "enum": ["passed", "failed", "blocked"] },
    "acceptance_complete": { "type": "boolean" },
    "manifest_sha256": { "$ref": "#/$defs/sha256" },
    "generated_at": { "type": "string", "format": "date-time" },
    "requirements": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": { "$ref": "#/$defs/requirement_result" }
    },
    "completion_report": { "$ref": "./completion-report.schema.json" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "requirement_id": { "type": "string", "pattern": "^SI-AC-(0[1-9]|1[0-9]|2[0-4])$" },
    "declared_status": { "enum": ["planned", "static-only", "blocked", "passed"] },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "requirements"],
      "properties": {
        "schema_version": { "const": 1 },
        "requirements": {
          "type": "array",
          "minItems": 24,
          "maxItems": 24,
          "items": { "$ref": "#/$defs/requirement" }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "phase", "status", "contracts", "tests", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/requirement_id" },
        "description": { "type": "string", "minLength": 1 },
        "phase": { "enum": ["P0", "P1", "P2"] },
        "status": { "$ref": "#/$defs/declared_status" },
        "contracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "tests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^tests\\.[A-Za-z0-9_.]+\\.test_[A-Za-z0-9_]+$" }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_requirement" }
        }
      }
    },
    "evidence_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["automated-test", "static-contract", "deferred"] },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "artifact_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "status", "reason"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "test_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "sha256", "exit_code", "status", "duration_ms", "reason"],
      "properties": {
        "selector": { "type": "string" },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "exit_code": { "type": ["integer", "null"] },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "reason": { "type": ["string", "null"] }
      }
    },
    "evidence_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "status", "reason"],
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "requirement_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "phase",
        "declared_status",
        "computed_status",
        "configured",
        "loaded",
        "enforced",
        "passing",
        "contracts",
        "tests",
        "evidence",
        "reasons"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/requirement_id" },
        "phase": { "enum": ["P0", "P1", "P2"] },
        "declared_status": { "$ref": "#/$defs/declared_status" },
        "computed_status": { "enum": ["planned", "static-only", "passed", "failed", "blocked"] },
        "configured": { "type": "boolean" },
        "loaded": { "type": "boolean" },
        "enforced": { "type": "boolean" },
        "passing": { "type": "boolean" },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/artifact_result" } },
        "tests": { "type": "array", "items": { "$ref": "#/$defs/test_result" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_result" } },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
