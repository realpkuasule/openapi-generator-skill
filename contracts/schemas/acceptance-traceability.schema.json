{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openapi-engineering.local/schemas/acceptance-traceability.schema.json",
  "title": "OpenAPI Engineering Acceptance Traceability Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_version",
    "status",
    "manifest_sha256",
    "generated_at",
    "requirements",
    "completion_report"
  ],
  "properties": {
    "report_version": { "const": 1 },
    "status": { "enum": ["passed", "failed", "blocked"] },
    "manifest_sha256": { "$ref": "#/$defs/sha256" },
    "generated_at": { "type": "string", "format": "date-time" },
    "requirements": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/requirement_result" }
    },
    "completion_report": {
      "$ref": "./completion-report.schema.json"
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "requirement_id": { "type": "string", "pattern": "^AC-(0[1-9]|1[0-2])$" },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "requirements"],
      "properties": {
        "schema_version": { "const": 1 },
        "requirements": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/requirement" }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "status",
        "contracts",
        "tests",
        "evidence"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/requirement_id" },
        "description": { "type": "string", "minLength": 1 },
        "status": { "enum": ["planned", "static-only", "blocked", "passed"] },
        "contracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "tests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_requirement" }
        }
      }
    },
    "evidence_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "required_status",
        "required_platforms",
        "require_unverified_empty"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["deterministic", "forward", "empirical", "security", "completion"]
        },
        "required_status": { "const": "passed" },
        "required_platforms": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["codex", "claude"] }
        },
        "require_unverified_empty": { "type": "boolean" }
      }
    },
    "artifact_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "status", "reason"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "evidence_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "sha256",
        "source_status",
        "platforms",
        "status",
        "reason"
      ],
      "properties": {
        "path": { "type": "string" },
        "kind": { "type": "string" },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "source_status": { "type": ["string", "null"] },
        "platforms": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["codex", "claude"] }
        },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "requirement_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "declared_status",
        "computed_status",
        "contracts",
        "tests",
        "evidence",
        "reasons"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/requirement_id" },
        "declared_status": { "enum": ["planned", "static-only", "blocked", "passed"] },
        "computed_status": { "enum": ["passed", "failed", "blocked"] },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/artifact_result" } },
        "tests": { "type": "array", "items": { "$ref": "#/$defs/artifact_result" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_result" } },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
